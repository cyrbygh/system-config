export _NIXOS_CONF_DIR="${HOME}/.system-config/systems/current/nixos"
export _NIXOS_CONF_FILE="${_NIXOS_CONF_DIR}/configuration.nix"

alias nixos-edit="vim ${_NIXOS_CONF_FILE}"
alias nixos-hardware-edit="vim ${_NIXOS_CONF_DIR}/hardware-configuration.nix"
alias nixos-apply='sudo nixos-rebuild switch --flake "$HOME/.system-config#$(basename $(readlink $HOME/.system-config/systems/current))"'
alias nixos-update-packages="nix flake update ~/.system-config/systems/_shared/nixos"

